<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wall Join Cleanup"
        Height="320" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Assembly:" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox Grid.Row="0" Grid.Column="1"
                  x:Name="cb_assembly" Margin="0,4"
                  IsEditable="False"/>

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Stud Type:" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox Grid.Row="1" Grid.Column="1"
                  x:Name="cb_stud_type" Margin="0,4"
                  IsEditable="False"/>

        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Blocking Type:" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox Grid.Row="2" Grid.Column="1"
                  x:Name="cb_blocking_type" Margin="0,4"
                  IsEditable="False"/>

        <TextBlock Grid.Row="3" Grid.ColumnSpan="2"
                   x:Name="tb_summary" Margin="0,10,0,0"
                   TextWrapping="Wrap" FontStyle="Italic"
                   Foreground="Gray"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button x:Name="btn_ok" Content="Apply"
                    Width="90" Height="28" Margin="0,0,8,0"
                    IsDefault="True"
                    Click="btn_ok_click"/>
            <Button x:Name="btn_cancel" Content="Cancel"
                    Width="90" Height="28"
                    IsCancel="True"
                    Click="btn_cancel_click"/>
        </StackPanel>
    </Grid>
</Window>
