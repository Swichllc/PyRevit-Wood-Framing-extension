<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Frame Wall Configuration"
        Height="620" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Stud Family/Type -->
        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Stud Type:" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox Grid.Row="0" Grid.Column="1"
                  x:Name="cb_stud_type" Margin="0,4"
                  IsEditable="False"/>

        <!-- Plate Family/Type -->
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Plate Type:" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox Grid.Row="1" Grid.Column="1"
                  x:Name="cb_plate_type" Margin="0,4"
                  IsEditable="False"/>

        <!-- Header Family/Type -->
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Header Type:" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox Grid.Row="2" Grid.Column="1"
                  x:Name="cb_header_type" Margin="0,4"
                  IsEditable="False"/>

        <!-- Stud Spacing -->
        <TextBlock Grid.Row="3" Grid.Column="0"
                   Text="Stud Spacing:" VerticalAlignment="Center" Margin="0,8"/>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,8">
            <RadioButton x:Name="rb_16oc" Content='16" OC' GroupName="spacing"
                         IsChecked="True" Margin="0,0,16,0"/>
            <RadioButton x:Name="rb_24oc" Content='24" OC' GroupName="spacing"
                         Margin="0,0,16,0"/>
            <RadioButton x:Name="rb_custom" Content="Custom:" GroupName="spacing"/>
            <TextBox x:Name="tb_custom_spacing" Width="50" Margin="4,0,0,0"
                     Text="16" IsEnabled="False"/>
            <TextBlock Text=' "' VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Top Plate Count -->
        <TextBlock Grid.Row="4" Grid.Column="0"
                   Text="Top Plates:" VerticalAlignment="Center" Margin="0,4"/>
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <RadioButton x:Name="rb_single_top" Content="Single"
                         GroupName="topplate" Margin="0,0,16,0"/>
            <RadioButton x:Name="rb_double_top" Content="Double"
                         GroupName="topplate" IsChecked="True"/>
        </StackPanel>

        <!-- Mid-plate option -->
        <TextBlock Grid.Row="5" Grid.Column="0"
                   Text="Mid Plates:" VerticalAlignment="Center" Margin="0,4"/>
        <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,4">
            <CheckBox x:Name="chk_mid_plates"
                      Content='Add from bottom plate baseline'
                      IsChecked="True" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Height interval:" VerticalAlignment="Center"/>
                <TextBox x:Name="tb_mid_plate_height" Width="55" Margin="6,0,0,0"
                         Text="8"/>
                <TextBlock Text=" ft" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="6" Grid.Column="0"
                   Text="Wall Line:" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox Grid.Row="6" Grid.Column="1"
                  x:Name="cb_wall_layer_mode" Margin="0,4"
                  IsEditable="False"/>

        <!-- Options -->
        <TextBlock Grid.Row="7" Grid.Column="0"
                   Text="Options:" VerticalAlignment="Top" Margin="0,8"/>
        <StackPanel Grid.Row="7" Grid.Column="1" Margin="0,8">
            <CheckBox x:Name="chk_king_studs" Content="King studs at openings"
                      IsChecked="True" Margin="0,2"/>
            <CheckBox x:Name="chk_jack_studs" Content="Jack/trimmer studs"
                      IsChecked="True" Margin="0,2"/>
            <CheckBox x:Name="chk_cripple_studs" Content="Cripple studs"
                      IsChecked="True" Margin="0,2"/>
        </StackPanel>

        <!-- Wall base source -->
        <TextBlock Grid.Row="8" Grid.Column="0"
                   Text="Wall Base:" VerticalAlignment="Center" Margin="0,8"/>
        <CheckBox Grid.Row="8" Grid.Column="1"
                  x:Name="chk_support_top"
                  Content="Use selected support host top as wall base"
                  Margin="0,8"/>

        <!-- Summary -->
        <TextBlock Grid.Row="9" Grid.ColumnSpan="2"
                   x:Name="tb_summary" Margin="0,8"
                   TextWrapping="Wrap" FontStyle="Italic"
                   Foreground="Gray"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="11" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button x:Name="btn_ok" Content="Frame"
                    Width="90" Height="28" Margin="0,0,8,0"
                    IsDefault="True"
                    Click="btn_ok_click"/>
            <Button x:Name="btn_cancel" Content="Cancel"
                    Width="90" Height="28"
                    IsCancel="True"
                    Click="btn_cancel_click"/>
        </StackPanel>
    </Grid>
</Window>
