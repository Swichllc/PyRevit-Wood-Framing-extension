<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Frame Floor"
        Width="430" Height="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Joist Family:" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox Grid.Row="0" Grid.Column="1"
                  x:Name="cb_joist_type" Margin="0,4" IsEditable="False"/>

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Rim Family:" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox Grid.Row="1" Grid.Column="1"
                  x:Name="cb_rim_type" Margin="0,4" IsEditable="False"/>

        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Spacing:" VerticalAlignment="Center" Margin="0,8"/>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,8">
            <RadioButton x:Name="rb_16oc" Content='16&quot; OC' GroupName="spacing"
                         IsChecked="True" Margin="0,0,16,0"/>
            <RadioButton x:Name="rb_24oc" Content='24&quot; OC' GroupName="spacing"
                         Margin="0,0,16,0"/>
            <RadioButton x:Name="rb_custom" Content="Custom:" GroupName="spacing"/>
            <TextBox x:Name="tb_custom_spacing" Width="50" Margin="4,0,0,0"
                     Text="16" IsEnabled="False"/>
            <TextBlock Text=' &quot;' VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Grid.ColumnSpan="2"
                   x:Name="tb_summary" Margin="0,10,0,0"
                   TextWrapping="Wrap" FontStyle="Italic" Foreground="Gray"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="btn_ok" Content="Frame" Width="90" Height="28"
                    Margin="0,0,8,0" IsDefault="True"/>
            <Button x:Name="btn_cancel" Content="Cancel" Width="90" Height="28"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
