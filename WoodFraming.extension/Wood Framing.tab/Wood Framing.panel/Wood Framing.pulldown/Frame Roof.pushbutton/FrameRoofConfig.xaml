<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Single-Slope Roof Framing"
        Width="400" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <StackPanel Margin="12">
        <!-- Mode -->
        <TextBlock Text="Framing Mode" FontWeight="Bold" Margin="0,0,0,4"/>
        <RadioButton x:Name="rb_stick" Content="Stick Frame (rafters + ridge)"
                     IsChecked="True" Margin="0,2"/>
        <RadioButton x:Name="rb_truss" Content="Truss Placement"
                     Margin="0,2"/>

        <!-- Rafter / Truss Type -->
        <TextBlock Text="Rafter / Truss Family" FontWeight="Bold" Margin="0,12,0,4"/>
        <ComboBox x:Name="cb_rafter_type" Height="24"/>

        <!-- Ridge Board Type -->
        <TextBlock Text="Ridge Board Family" FontWeight="Bold" Margin="0,12,0,4"/>
        <ComboBox x:Name="cb_ridge_type" Height="24"/>

        <!-- Spacing -->
        <TextBlock Text="Spacing" FontWeight="Bold" Margin="0,12,0,4"/>
        <StackPanel Orientation="Horizontal">
            <RadioButton x:Name="rb_16oc" Content='16" OC' IsChecked="True" Margin="0,0,16,0"/>
            <RadioButton x:Name="rb_24oc" Content='24" OC' Margin="0,0,16,0"/>
            <RadioButton x:Name="rb_custom_sp" Content="Custom:"/>
            <TextBox x:Name="tb_custom_spacing" Width="50" Margin="4,0,0,0"
                     Text="16" IsEnabled="False"/>
            <TextBlock Text=' "' VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Collar Ties (stick mode only) -->
        <CheckBox x:Name="chk_collar_ties" Content="Include Collar Ties"
                  IsChecked="True" Margin="0,12,0,0"/>

        <!-- Ceiling framing -->
        <CheckBox x:Name="chk_ceiling_joists" Content="Include Ceiling Joists"
              IsChecked="True" Margin="0,6,0,0"/>
        <CheckBox x:Name="chk_roof_kickers" Content="Include Roof Kickers"
              IsChecked="True" Margin="0,6,0,0"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btn_ok" Content="Frame" Width="80" Height="28"
                    IsDefault="True" Margin="0,0,8,0"/>
            <Button x:Name="btn_cancel" Content="Cancel" Width="80" Height="28"
                    IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
