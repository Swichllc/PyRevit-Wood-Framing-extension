<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Multi-Slope Roof Framing"
    Width="420" Height="430"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <StackPanel Margin="12">
        <TextBlock Text="Rafter Family" FontWeight="Bold" Margin="0,0,0,4"/>
        <ComboBox x:Name="cb_rafter_type" Height="24"/>

        <TextBlock Text="Ridge Board Family" FontWeight="Bold" Margin="0,12,0,4"/>
        <ComboBox x:Name="cb_ridge_type" Height="24"/>

        <TextBlock Text="Eave / Rim Board Family" FontWeight="Bold" Margin="0,12,0,4"/>
        <ComboBox x:Name="cb_edge_type" Height="24"/>

        <TextBlock Text="Spacing" FontWeight="Bold" Margin="0,12,0,4"/>
        <StackPanel Orientation="Horizontal">
            <RadioButton x:Name="rb_16oc" Content='16&quot; OC' IsChecked="True" Margin="0,0,16,0"/>
            <RadioButton x:Name="rb_24oc" Content='24&quot; OC' Margin="0,0,16,0"/>
            <RadioButton x:Name="rb_custom_sp" Content="Custom:"/>
            <TextBox x:Name="tb_custom_spacing" Width="50" Margin="4,0,0,0"
                     Text="16" IsEnabled="False"/>
            <TextBlock Text=' &quot;' VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btn_ok" Content="Frame" Width="80" Height="28"
                    IsDefault="True" Margin="0,0,8,0"/>
            <Button x:Name="btn_cancel" Content="Cancel" Width="80" Height="28"
                    IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
